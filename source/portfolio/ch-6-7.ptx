            <section xmlns:xi="http://www.w3.org/2001/XInclude">
                <title>Chapter 6 and 7: Continuity and Limits</title>
                    
                     <program language="latex" line-numbers="yes">
                        <code>  
  \documentclass{article}
  \usepackage{amssymb, amsmath}
  \newcommand{\lt}{&lt;}
  \newcommand{\gt}{&gt;}
  \begin{document}
    \title{Math 317: Chapter 6 and 7 Portfolio}
    \author{Your name here}
    \maketitle
    \begin{enumerate}
        \item[Problem 6.3] Prove each of the following real functions is continuous using Definition 6.2.
        \begin{enumerate}
            \item $f:\mathbb{R} \to \mathbb{R}$ defined via $f(x)=x$.
            \item $g: \mathbb{R} \to \mathbb{R}$ defined via $g(x)=2x$.
            \item $h: \mathbb{R} \to \mathbb{R}$ defined via $h(x)=x+3$.
        \end{enumerate}
        \item[Solution 6.3]

        \item[Problem 6.4] Prove that every linear function $f:\mathbb{R} \to \mathbb{R}$ given by $f(x) = mx + b$ is continuous. 
        \item[Solution 6.4]

        \item[Problem 6.5] Define $f: \mathbb{N} \to \mathbb{R}$ via $f(x)=1$. Notice the domain! Determine where $f$ is continuous and justify your assertion. 
        \item[Solution 6.5]

        \item[Problem 6.6] Find an example of a real function $f$ that satisfies each of the following:
            \begin{enumerate}
                \item[(i)] $1 \in \text{Dom}(f)$;
                \item[(ii)] For any open interval $J$ containing $1$, there is an open interval $I$ containing $f(1)$ such that if $x \in \text{Dom}(f) \cap J$, then $f(x) \in I$;
                \item[(iii)] $f$ is not continuous at $1$.
            \end{enumerate}
        \item[Solution 6.6]

        \item[Problem 6.7] Suppose $f$ is a real function such that $a \in \text{Dom}(f)$. Prove that $f$ is continuous at $a$ if and only if for every $\varepsilon \gt 0$, there exists $\delta \gt 0$ such that if $x \in \text{Dom}(f)$ and $|x-a| \lt \delta$, the $|f(x)-f(a)| \lt \varepsilon$.
        \item[Solution 6.7]

        \item[Problem 6.8] Draw a figure in the spirit of Figure 6.1 that captures the essence of Problem 6.7.
        \item[Solution 6.8]

        \item[Problem 6.9] Define $f: \mathbb{R} \to \mathbb{R}$ via
            \[
                f(x) = \begin{cases}
                        1 &amp; \text{if } x \in [0,1] \\
                        0 &amp; \text{otherwise.}
                        \end{cases}
            \]
            Determine where $f$ is continuous and justify your assertion.
        \item[Solution 6.9]

        \item[Problem 6.10] Define $g:\{0\} \to \mathbb{R}$ via $g(0)=0$. Prove that $g$ is continuous at $0$. 
        \item[Solution 6.10]

        \item[Problem 6.11] Define $f: \mathbb{R} \to \mathbb{R}$ via
            \[
                f(x) = \begin{cases}
                        1 &amp; \text{if } x \in \mathbb{Q} \\
                        0 &amp; \text{otherwise.}
                        \end{cases}
            \]
            Determine where $f$ is continuous and justify your assertion.
        \item[Solution 6.11]

        \item[Problem 6.12] Define $f:\mathbb{R} \to \mathbb{R}$ via $f(x)=x^2$. Prove that $f$ is continuous. 
        \item[Solution 6.12]

        \item[Problem 6.13] Find a continuous real function $f$ and an open interval $I$ such that the preimage $f^{-1}(I)$ is not an open interval. 
        \item[Solution 6.13]

        \item[Problem 6.14] Suppose $f$ is a real function. Prove that $f$ is continuous if and only if the preimage $f^{-1}(U)$ of every open set $U$ is an open set intersected with the domain of $f$.
        \item[Solution 6.14]

        \item[Problem 6.15] \textit{This problem is optional to type up for your portfolio, but you should read and be familiar with the result.} \\ Suppose $f$ is a real function. Prove that $f$ is continuous if and only if the preimage $f^{-1}(I)$ of every open interval $I$ is an open set intersected with the domain of $f$.
        \item[Solution 6.15]

        \item[Problem 6.16] Define $f: \mathbb{R}\setminus \{0\} \to \mathbb{R}$ via $f(x) = \frac{1}{x}$. Determine where $f$ is continuous and justify your assertion.
        \item[Solution 6.16]   

        \item[Problem 6.18] Suppose $f$ is a real function such that $a \in \text{Dom}(f)$. Prove that $f$ is continuous at $a$ if and only if $f$ is sequentially continuous at $a$.
        \item[Solution 6.18]

        \item[Problem 6.19] Suppose $f$ and $g$ are real functions that are continuous at $a$ and let $c \in \mathbb{R}$. Prove that each of the following functions is also continuous at $a$.
            \begin{enumerate}
                \item $cf$
                \item $f+g$
                \item $f-g$
                \item $fg$ \\ \textit{You may assume the relevant result mentioned (but not proven) about the product of convergent sequences from Chapter 5. This is also a good opportunity for more practice if you'd like it!}
            \end{enumerate}
        \item[Solution 6.19]

        \item[Problem 6.20] Prove that every polynomial is continuous on all of $\mathbb{R}$.
        \item[Solution 6.20]

        \item[Problem 6.21] Suppose $f:\mathbb{R} \to \mathbb{R}$ is a continuous function and consider the closed interval $[a,b]$. Is the image $f([a,b])$ always a closed interval? If so, prove it. Otherwise, provide a counterexample.
        \item[Solution 6.21]

        \item[Problem 6.22] Prove that if $f:\mathbb{R} \to \mathbb{R}$ is a continuous function and $K$ is a compact set, the the image $f(K)$ is compact.
        \item[Solution 6.22]

        \item[Problem 6.23] Suppose $f$ is a real function and let $I=[a,b]$ be a closed interval. Prove that if $f$ is continuous on $I$, then there exists $x_M\in I$ such that $f(x_M)\geq f(x)$ for all $x \in I$.
        \item[Solution 6.23]

        \item[Problem 6.24] Is the hypothesis that $I$ is closed needed in the Extreme Value Theorem? Justify your assertion.
        \item[Solution 6.24]

        \item[Problem 6.25] Is the converse of the Extreme Value Theorem true? That is, if a function attains a maximum value over a closed interval, does that imply that the function is continuous? If so, prove it. Otherwise, provide a counterexample.
        \item[Solution 6.25]

        \item[Problem 6.26] Let $f:[0,1] \to \mathbb{R}$ and assume that the image $f([0,1])$ has a supremum. Prove that there is a sequence of points $(p_n)_{n=1}^\infty$ in $[0,1]$ such that $(f(p_n))_{n=1}^\infty$ converges to that supremum. Does this show that $f$ is continuous on $[0,1]$?
        \item[Solution 6.26]

        \item[Problem 6.27] Prove that if $f: \mathbb{R} \to \mathbb{R}$ is a continuous function and $C$ is a connected set, then the image $f(C)$ is connected.
        \item[Solution 6.27]

        \item[Problem 6.28] Suppose $f$ is a real function and let $I=[a,b]$ be a closed interval. Prove that if $f$ is continuous on $I$ such that $f(a) \lt 0 \lt f(b)$ or $f(b) \lt 0 \lt f(a)$, then there exists $r \in I$ such that $f(r) =0$.
        \item[Solution 6.28]

        \item[Problem 6.29] Suppose $f$ is a real function and let $I=[a,b]$ be a closed interval. Prove that if $f$ is continuous on $I$ such that $f(a) \lt c \lt f(b)$ or $f(b) \lt c \lt f(a)$, then there exists $r \in I$ such that $f(r) =c$.
        \item[Solution 6.29]

        \item[Problem 6.30] Is the converse of the Intermediate Value Theorem true? If so, prove it. Otherwise, provide a counterexample. 
        \item[Solution 6.30]

        \item[Problem 6.31] Let $f:[0,1] \to \mathbb{R}$ be a function such that $f(0)=-1$, $f(1)=1$, and $f([0,1])=\{-1,1\}$. Prove that there exists $a \in [0,1]$ such that $f$ is not continuous at $a$. 
        \item[Solution 6.31]

        \item[Problem 6.33] Let $f$ be a real function. Prove that if $f$ is uniformly continuous, then $f$ is continuous. 
        \item[Solution 6.33]

        \item[Problem 6.34] Define $f: \mathbb{R} \to \mathbb{R}$ via $f(x) = 5x -3$. Prove that $f$ is uniformly continuous.
        \item[Solution 6.34]

        \item[Problem 6.35] Define $f: \mathbb{R} \to \mathbb{R}$ via $f(x) = x^2$. Prove that $f$ is not uniformly continuous.
        \item[Solution 6.35]

        \item[Problem 6.36] Define $f: [0,\infty)\to \mathbb{R}$ via $f(x) = \sqrt{x}$. Prove that $f$ is uniformly continuous.
        \item[Solution 6.36]

        \item[Problem 6.37] Define $f: \mathbb{R}\setminus \{0\} \to \mathbb{R}$ via $f(x) = \frac{1}{x}$. Determine whether $f$ is uniformly continuous.
        \item[Solution 6.37]

        \item[Problem 6.38] Let $f: K \to \mathbb{R}$ be a continuous real function such that $K$ is compact. Prove that $f$ is uniformly continuous.
        \item[Solution 6.38]

        \item[Problem 7.2] Why do we require $0 \lt |x-a|$ in Definition 7.1?
        \item[Solution 7.2]

        \item[Problem 7.3] Why do you think we require $a$ to be an accumulation point of the domain of $f$? What happens if $a \in \text{Dom}(f)$ but $a$ is not an accumulation point of $\text{Dom}(f)$? Such points are called \textbf{isolated points} of the domain of $f$.
        \item[Solution 7.3]

        \item[Problem 7.6] Prove that $\displaystyle \lim_{x\to 1}(17x-42)=-25$ using Definition 7.1.
        \item[Solution 7.6]

        \item[Problem 7.7] Prove that $\displaystyle \lim_{x\to 2}x^3=8$ using Definition 7.1.
        \item[Solution 7.7]

        \item[Problem 7.8] Define $f:\mathbb{R} \to \mathbb{R}$ via
            \[
            f(x) = \begin{cases}
                    x, &amp; \text{if } x \neq 0 \\
                    17, &amp; \text{if } x =0.
                    \end{cases}
            \]
        Prove that $\displaystyle \lim_{x\to 0}f(x)=0$ using Definition 7.1.
        \item[Solution 7.8]

        \item[Problem 7.9] Define $f:\mathbb{R} \to \mathbb{R}$ via
            \[
            f(x) = \begin{cases}
                    1, &amp; \text{if } x \leq 0 \\
                    -1, &amp; \text{if } x \gt 0.
                    \end{cases}
            \]
        Using Definition 7.1, prove that $\displaystyle \lim_{x\to 0}f(x)$ does not exist.
        \item[Solution 7.9]

        \item[Problem 7.10] Define $f:\mathbb{R} \to \mathbb{R}$ via
            \[
            f(x) = \begin{cases}
                    1, &amp; \text{if } x \in \mathbb{Q} \\
                    0, &amp; \text{otherwise. }
                    \end{cases}
            \]
        Using Definition 7.1, prove that $\displaystyle \lim_{x\to a}f(x)$ does not exist for all $a \in \mathbb{R}$.
        \item[Solution 7.10]

        \item[Problem 7.11] Let $f$ be a real function. Prove that if $\displaystyle \lim_{x\to a}f(x)$ exists, then the limit is unique.
        \item[Solution 7.11]

        \item[Problem 7.12] Let $f$ be a real function and let $a$ be an accumulation point of $\text{Dom}(f)$. Prove that $\displaystyle \lim_{x\to a}f(x)$ exists if and only if for every sequence $(p_n)$ in $\text{Dom}(f) \setminus\{a\}$ converging to $a$, the sequence $(f(p_n))$ converges, in which case, $\displaystyle \lim_{x\to a}f(x)$ equals the limit of the sequence $(f(p_n))$.
        \item[Solution 7.12]

        \item[Problem 7.13] Let $f,g:A \to \mathbb{R}$ be real functions. Prove each of the following using Definition 7.1 or Problem 7.12.
            \begin{enumerate}
                \item If $c \in \mathbb{R}$, then $\displaystyle \lim_{x\to a}c = c$.
                \item If $\displaystyle \lim_{x\to a}f(x)$ and $\displaystyle \lim_{x\to a}g(x)$ both exist, then
                \[
                \lim_{x\to a}(f(x) \pm g(x)) = \lim_{x\to a}f(x) \pm \lim_{x\to a}g(x).
                \]
                \item If $\displaystyle \lim_{x\to a}f(x)$ and $\displaystyle \lim_{x\to a}g(x)$ both exist, then
                \[
                \lim_{x\to a}(f(x) \cdot g(x)) = \lim_{x\to a}f(x) \cdot \lim_{x\to a}g(x).
                \]
                \item If $c \in \mathbb{R}$ and $\displaystyle \lim_{x\to a}f(x)$ exists, then
                \[
                \lim_{x\to a}(c \cdot f(x)) = c \cdot\lim_{x\to a}f(x).
                \]
                \item If $\displaystyle \lim_{x\to a}f(x)$ and $\displaystyle \lim_{x\to a}g(x)$ both exist and $\displaystyle \lim_{x\to a}g(x) \neq 0$, then
                \[
                \lim_{x\to a}\frac{f(x)}{ g(x)} = \frac{\lim_{x\to a}f(x) }{ \lim_{x\to a}g(x)}.
                \]
                \item If $f$ is continuous at $b$ and $\displaystyle \lim_{x\to a}g(x) =b$, then
                \[
                \lim_{x\to a}f(g(x)) = f(\lim_{x\to a}g(x)) = f(b).
                \]
            \end{enumerate}
        \item[Solution 7.13]

        \item[Problem 7.14] Let $f$ and $g$ be real functions with $A = \text{Dom}(f)=\text{Dom}(g)$ and let $a$ be an accumulation point of $A$. Prove that if there exists an open interval $J$ containing $a$ such that $f(x)=g(x)$ for all $x \in (J\cap A)\setminus \{a\}$, then
        \[
        \lim_{x\to a}f(x) = \lim_{x\to a}g(x)
        \]
        provided one of the limits exists.
        \item[Solution 7.14]

        \textit{This is the end of Chapter 6 and 7 problems.}


 

    \end{enumerate}  
