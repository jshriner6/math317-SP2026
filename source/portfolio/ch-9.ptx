<?xml version="1.0" encoding="UTF-8"?>
        
        
            <section xmlns:xi="http://www.w3.org/2001/XInclude">
                <title>Chapter 9: Integration</title>
                    
                     <program language="latex" line-numbers="yes">
                        <code>  
  \documentclass{article}
  \usepackage{amssymb, amsmath}
  \newcommand{\lt}{&lt;}
  \newcommand{\gt}{&gt;}
  \begin{document}
    \title{Math 317: Chapter 9 Portfolio}
    \author{Your name here}
    \maketitle
    \begin{enumerate}

        \item[Problem 9.2] Give some partitions, regular and not regular, of $[0,1]$, $[2,4]$, and $[-1,0]$. 
        \item[Solution 9.2]

        \item[Problem 9.7] Draw pictures that capture the concepts of upper and lower Riemann sums. 
        \item[Solution 9.7]

        \item[Problem 9.8] Give an example of an interval $[a,b]$, partition $P$, and bounded real function $f$ such that $U_p(f)$ is not a Riemann sum. 
        \item[Solution 9.8]

        \item[Problem 9.9] Define $f:[0,1] \to \mathbb{R}$ via 
            \[
            f(x) = \begin{cases}
                    0, &amp; \text{if } x \in (0,1] \\
                    1, &amp; \text{if } x=0.
                    \end{cases}
            \]
            \begin{enumerate}
                \item Show that $U_P(f) \gt 0$ for all partitions of $[0,1]$.
                \item Show that for any positive number $\varepsilon$ there is a partition $P_\varepsilon$ such that $U_{P_\varepsilon}(f) \lt \varepsilon$.
                \item Fully describe all lower sums of $f$ on $[0,1]$.
            \end{enumerate}
        \item[Solution 9.9]

        \item[Problem 9.10] Define $f:[0,1] \to \mathbb{R}$ via $f(x)=x$. For each $n \in \mathbb{N}$, let $P_n$ be the regular partition of $[0,1]$ given by $\{0, \frac{1}{n}, \frac{2}{n}, \dots, \frac{n-1}{n}, 1\}$.
            \begin{enumerate}
                \item Compute $U_{P_5}(f)$.
                \item Give a formula for $U_{P_n}(f)$.
                \item Compute $L_{P_5}(f)$.
                \item Give a formula for $L_{P_n}(f)$.
            \end{enumerate}
        \item[Solution 9.10]

        \item[Problem 9.11] Suppose that $f$ is a bounded real function on $[a,b]$ with lower bound $m$ and upper bound $M$. Show that for any partition $P$ of $[a,b]$, $U_P(f) \leq M(b-a)$ and $L_P(f) \geq m(b-a)$.
        \item[Solution 9.11]

        \item[Problem 9.12] Suppose that $f$ is a bounded real function on $[a,b]$ and $P$ is a partition of $[a,b]$. Show that $L_P(f) \leq U_P(f)$.
        \item[Solution 9.12]

        \item[Problem 9.14] Compute the upper and lower integrals for the function in Problem 9.9.
        \item[Solution 9.14]

        \item[Problem 9.15] Define $f: \mathbb{R} \to \mathbb{R}$ via 
            \[
            f(x) = \begin{cases}
                    1, &amp; \text{if } x \in \mathbb{Q} \\
                    0, &amp; \text{if } x \in \mathbb{R} \setminus \mathbb{Q}.
                    \end{cases}
            \]
            Show that $\underline{\int_0^1 f}  \lt \overline{\int_0^1 f}$.
        \item[Solution 9.15]

        \item[Problem 9.17] Let $f$ be a bounded real function with domain $[a,b]$. Prove that if $P$ and $Q$ are partitions of $[a,b]$ such that $Q$ is a refinement of $P$, then $L_P(f) \leq L_Q(f)$ and $U_P(f) \geq U_Q(f)$.
        \item[Solution 9.17]

        \item[Problem 9.18] Suppose $f$ is a bounded real function on $[a,b]$. Use the previous problem to prove that 
            \[
            \underline{\int_a^b f}  \leq \overline{\int_a^b f}.
            \]
        \item[Solution 9.18]

        \item[Problem 9.19] Suppose $f$ is continuous on $[a,b]$ such that $f(x) \geq 0$ for all $x \in [a,b]$ and that for some $z \in [a,b]$, $f(z) \gt 0$. Explain why $\overline{\int_a^b f}$ exists and then show that $\overline{\int_a^b f} \gt 0$.
        \item[Solution 9.19]

        \item[Problem 9.21] Give an example of a function $f$ and an interval $[a,b]$ for which we know $\int_a^bf$ does not exist.
        \item[Solution 9.21]

        \item[Problem 9.22] Is the function in Problem 9.9 integrable over $[0,1]$? If so, determine the value of the corresponding integral. If not, explain why.
        \item[Solution 9.22]

        \item[Problem 9.23] Prove that every constant real function is integrable over every interval $[a,b]$.
        \item[Solution 9.23]

        \item[Problem 9.24] Suppose $f$ is a bounded real function on $[a,b]$. Then $f$ is (Riemann) integrable if and only if for every $\varepsilon \gt 0$, there exists a partition $P$ of $[a,b]$ such that $U_P(f) - L_P(f) \lt \varepsilon$. 
        \item[Solution 9.24]

        \item[Problem 9.25] Define $f: \mathbb{R} \to \mathbb{R}$ defined via $f(x) =x$. Using the tools we currently have at our disposal, prove that $f$ is integrable on $[0,1]$ and compute the value of the integral. 
        \item[Solution 9.25]

        \item[Problem 9.27] Prove that if $f$ is a bounded monotonic real function on $[a,b]$, then $f$ is integrable on $[a,b]$. 
        \item[Solution 9.27]

        \item[Problem 9.28] Prove that each of the following exist. Do you know the value of any of these integrals knowing what we know now and perhaps some well-known area formulas?
            \begin{enumerate}
                \item $\int_1^2 x^2 dx$
                \item $\int_1^{17} e^{-x} dx$
                \item $\int_0^1 \sqrt{1-x^2} dx$
                \item $\int_0^1 \sqrt{1+x^4} dx$
            \end{enumerate}
        \item[Solution 9.28]

        \item[Problem 9.29] Suppose $f$ and $g$ are integrable real functions on $[a,b]$ and let $c \in \mathbb{R}$. Prove each of the following:
            \begin{enumerate}
                \item The function $cf$ is integrable on $[a,b]$ and $\int_a^b cf = c\int_a^bf$.
                \item The function $f+g$ is integrable on $[a,b]$ and $\int_a^b (f+g) = \int_a^b f + \int_a^b g$.
                \item The function $f-g$ is integrable on $[a,b]$ and $\int_a^b (f-g) = \int_a^b f - \int_a^b g$.
            \end{enumerate}
        \item[Solution 9.29]

        \item[Problem 9.30] Find two real function $f$ and $g$ that are integrable on $[0,1]$ such that $fg$ is also integrable on $[0,1]$ but 
            \[
            \left(\int_0^1f\right)\left(\int_0^1 g\right) \neq \int_0^1 fg.
            \]
        \item[Solution 9.30]

        \item[Problem 9.31] Prove that if $f$ is integrable on $[a,b]$, then there exists $m,M \in \mathbb{R}$ such that 
            \[
            m(b-a) \leq \int_a^b f \leq M(b-a).
            \]
        \item[Solution 9.31]

        \item[Problem 9.32] Assume that $[a,b]$ is a closed interval and suppose $f$ is integrable on $[a,c]$ and $[c,b]$ for $c \in (a,b)$. Show that $f$ is integrable on $[a,b]$ and that 
            \[
            \int_a^b f = \int_a^c f + \int_c^b f.
            \]
        \item[Solution 9.32]

        \item[Problem 9.33] Suppose $f$ is integrable on $[a,b]$. Prove that for every $c \in \mathbb{R}$, the function $g$ defined via $g(x) = f(x-c)$ is integrable on $[a+c,b+c]$ and 
            \[
            \int_a^b f(x) dx = \int_{a+c}^{b+c} f(x-c) dx.
            \]
        \item[Solution 9.33]

        \item[Problem 9.34] Suppose $f$ is continuous on $[a,b]$. Prove that for every $\varepsilon \gt 0$, there exists a partition $P=\{t_0=a,t_1, \dots, t_{n-1},t_n=b\}$ of $[a,b]$ such that for each $1 \leq i \leq n$, if $u,v \in [t_{i-1},t_i]$, then $|f(u)-f(v)| \lt \varepsilon$.
        \item[Solution 9.34]

        \item[Problem 9.35] Prove that if $f$ is continuous on $[a,b]$, then $f$ is integrable on $[a,b]$.
        \item[Solution 9.35]

        \item[Problem 9.36] Is the converse of the previous problem true? If so, prove it. Otherwise, provide a counterexample.
        \item[Solution 9.36]

        \item[Problem 9.37] Suppose $f$ is continuous on $[a,b]$. Prove that 
            \[
            \left| \int_a^b f \right| \leq \int_a^b |f|.
            \]
        \item[Solution 9.37]

        \item[Problem 9.39] Suppose $f$ is continuous on $[a,b]$. Prove that there exists $c \in [a,b]$ such that 
            \[
            \int_a^b f = f(c) (b-a).
            \]
        \item[Solution 9.39]

        \item[Problem 9.40] Suppose $f$ is integrable on $[a,b]$ and define $g:[a,b] \to \mathbb{R}$ via
            \[
            g(x) = \int_a^x f.
            \]
        Prove that $g$ is uniformly continuous on $[a,b]$.
        \item[Solution 9.40]
    
        \item[Problem 9.41] Suppose $f$ is continuous on $[a,b]$ and define $F: [a,b] \to \mathbb{R}$ via
            \[
            F(x) = \int_a^x f.
            \]
        Prove that for each $c \in (a,b)$, $F$ is differentiable at $c$ and $F'(c) = f(c)$.
        \item[Solution 9.41]

        \item[Problem 9.42] Suppose $f$ is a real function whose domain includes $[a,b]$ such that $f$ is differentiable at each point of $[a,b]$, and the function $f'$ is continuous at each point in $[a,b]$. Prove that
            \[
            \int_a^b f' = f(b) - f(a).
            \]
        \item[Solution 9.42]

        \item[Problem 9.43] Using Problem 9.42 and your knowledge of antiderivatives from first semester calculus, compute the integrals in parts (a) and (b) of Problem 9.28. 
        \item[Solution 9.43]
        
        \item[Problem 9.44] According to WolframAlpha,
            \[
            \int_0^1 \frac{1}{\sqrt{x}}dx = 2.
            \]
        Explain why the techniques of this chapter cannot be used to verify this. How might one go about computing this integral? What definitions are needed?
        \item[Solution 9.44]
        
        \textit{This is the end of Chapter 9 problems. Congratulations and good work!}

    \end{enumerate}  
  \end{document}          
                        </code>
