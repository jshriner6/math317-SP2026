<pretext>
    <article xml:id="notes">
        <worksheet xml:id="sec-5-2">
        <title><m>\S 5.2</m>: Properties of Convergent Sequences</title>


				<exercise>
                    <title>Problems</title>
                    <task workspace="2in">
                        <statement>
                            <p>
                            Prove that if <m>c</m> is a real number and <m>(p_{n})_{n=1}^{\infty}</m> converges to <m>x</m>, then the sequence <m>(cp_{n})_{n=1}^{\infty}</m> converges to <m>cx</m>.
                            </p>
                        </statement>
                    </task>

                    <task workspace="2in">
                        <statement>
                            <p>
                            Prove that if <m>(p_{n})_{n=1}^{\infty}</m> converges to <m>x</m> and <m>(q_{n})_{n=1}^{\infty}</m> converges to <m>y</m>, then the sequence <m>(p_{n}+q_{n})_{n=1}^{\infty}</m> converges to <m>x+y</m>.
                            </p>
                        </statement>
                    </task>


                    <task workspace="2in">
                        <statement>
                            <p>
                            If the sequence <m>(p_{n})_{n=1}^{\infty}</m> converges to <m>x</m>, then the image set <m>\{p_{n}\}_{n=1}^{\infty}</m> is bounded.
                            </p>
                        </statement>
                    </task>

                    <task workspace="2in">
                        <statement>
                            <p>
                            Find an example of a sequence <m>(p_{n})_{n=1}^{\infty}</m> such that its image set <m>\{p_{n}\}_{n=1}^{\infty}</m> is unbounded above and hence does not have a supremum.
                            </p>
                        </statement>
                    </task>

                    <task workspace="2in">
                        <statement>
                            <p>
                            Prove that if <m>(p_{n})_{n=1}^{\infty}</m> converges to <m>x</m> and <m>(q_{n})_{n=1}^{\infty}</m> converges to <m>0</m>, then <m>(p_{n} \cdot q_{n})_{n=1}^{\infty}</m> converges to <m>0</m>.
                            </p>
                        </statement>
                    </task>
                    
                </exercise>


    
                

        </worksheet>
    </article>
</pretext>