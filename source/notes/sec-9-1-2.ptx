    <article xml:id="notes">
        <worksheet xml:id="sec-9-1-2">
        <title><m>\S 9.1</m>: Introduction to Integration (Part 2)</title>

        <exercise>
                    <title>Problems</title>
                    <task workspace="8in">
                        <statement>
                            <p>
                            Suppose that <m>f</m> is a bounded real function on <m>[a,b]</m> with lower bound <m>m</m> and upper bound <m>M</m>.
Show that for any partition <m>P</m> of <m>[a,b]</m>, <m>U_{P}(f) \leq M(b-a)</m> and <m>L_{P}(f) \geq m(b-a)</m>.
                            </p>
                        </statement>
                    </task>

                    <task workspace="8in">
                        <statement>
                            <p>
                            Suppose that <m>f</m> is a bounded real function on <m>[a,b]</m> and <m>P</m> is a partition of <m>[a,b]</m>.
Show that <m>L_{P}(f) \leq U_{P}(f)</m>.
                            </p>
                        </statement>
                    </task>

                    
                </exercise>

