                <exercise>
                    <title>Problems</title>
                    <task workspace="8in">
                        <statement>
                            <p>
                            Let <m>f</m> be a bounded real function with domain <m>[a,b]</m>.
Prove that if <m>P</m> and <m>Q</m> are partitions of <m>[a,b]</m> such that <m>Q</m> is a refinement of <m>P</m>, then <m>L_{P}(f) \leq L_{Q}(f)</m> and <m>U_{P}(f) \geq U_{Q}(f)</m>.
                            </p>
                        </statement>
                    </task>

                    <task workspace="8in">
                        <statement>
                            <p>
                            Suppose <m>f</m> is a bounded real function on <m>[a,b]</m>.
Use the previous problem to prove that
<md>
  \underline{\int_a^b f}\leq \overline{\int_a^b f}.
</md>
                            </p>
                        </statement>
                    </task>

                    <task workspace="8in">
                        <statement>
                            <p>
                            Suppose <m>f</m> is continuous on <m>[a,b]</m> such that <m>f(x) \geq 0</m> for all <m>x \in [a,b]</m> and that for some <m>z \in [a,b]</m>, <m>f(z) \gt 0</m>.
Explain why <m>\overline{\int_a^b f}</m> exists and then show that <m>\overline{\int_a^b f}\gt 0</m>.
                            </p>
                        </statement>
                    </task>


                    
                </exercise>

